# ============================================================================
# Whale Hackathon — environment variables
# ============================================================================
# Copy to .env in apps/api/ and backend/ as needed. NEVER commit a real .env.
# Production values live in `fly secrets` and the Vercel dashboard.

# ─── Anthropic ──────────────────────────────────────────────────────────────
# Used by every agent (listener, interrogator, reporter). One key for both apps.
ANTHROPIC_API_KEY=

# ─── Vapi (P1: apps/api/) ───────────────────────────────────────────────────
# These drive the live phone interaction. The Mevrouw assistant's Vapi server
# URL must point to https://<P1_HOSTNAME>/vapi/webhooks once deployed.
VAPI_API_KEY=
VAPI_ASSISTANT_ID_MEVROUW=
VAPI_ASSISTANT_ID_SCAMMER=
VAPI_PHONE_NUMBER_ID=
MEVROUW_PHONE_NUMBER=

# ─── Inter-service wiring ───────────────────────────────────────────────────
# P1 forwards transcript chunks + end-of-call to P2 via this URL.
# Local dev: http://localhost:8000
# Fly.io:    http://<p2-app-name>.internal:8080
P2_INGEST_URL=http://localhost:8000

# P2's interrogator agent sends mid-call nudges to this URL (P1's nudge endpoint).
# Local dev: http://localhost:8080/internal/nudge
# Fly.io:    http://<p1-app-name>.internal:8080/internal/nudge
P1_WEBHOOK_URL=

# Where the vault is on disk (P2 reads + writes here).
# Local dev: leave empty — auto-detects ../../vault relative to backend/.
# Fly.io:    /data/vault (the mounted Volume).
VAULT_PATH=

# ─── Frontend (frontend/web/) ───────────────────────────────────────────────
# Public — baked into the client bundle at build time on Vercel.
# Points the dashboard's EventSource at P2's /events.
NEXT_PUBLIC_SSE_URL=

# Public — used for any direct calls to P1 (currently only the dev-only
# Start Demo button). Leave unset in production.
NEXT_PUBLIC_API_URL=

# Public — set to "true" only in dev to show the Start Demo button.
NEXT_PUBLIC_ENABLE_DEMO_TRIGGER=

# Server-side — used by the Next API proxy routes to read vault from P2.
BACKEND_URL=
