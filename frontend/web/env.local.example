# Copy this file to .env.local and fill in the values.
# Without NEXT_PUBLIC_SSE_URL, the frontend uses mock fixture replay (dev/demo mode).

# P1 SSE stream — emits BusEvent JSON (transcript_delta, extraction_update, etc.)
NEXT_PUBLIC_SSE_URL=http://localhost:8080/events

# P1 REST API — used by the "Start Demo" button to trigger an outbound call
NEXT_PUBLIC_API_URL=http://localhost:8080
